# Database
DATABASE_URL=postgresql+psycopg2://analytics:analytics@localhost:5433/analytics_mcp

# Google Cloud credentials (service account JSON path or inline JSON)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# GA4 / GTM API scopes (comma-separated)
GOOGLE_SCOPES=https://www.googleapis.com/auth/analytics.edit,https://www.googleapis.com/auth/tagmanager.edit.containers,https://www.googleapis.com/auth/bigquery

# GTM account ID (required for container creation)
GTM_ACCOUNT_ID=1234567

# Mock Google APIs for local dev / tests
MOCK_GOOGLE_APIS=true

# API authentication
API_SECRET_KEY=change-me-in-production
ADMIN_API_KEY=admin-key-change-me
READONLY_API_KEY=readonly-key-change-me

# Alert channels
ALERT_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# Scheduler
HEALTH_CHECK_INTERVAL_MINUTES=60

# Plugin blueprints directory (optional override)
PLUGIN_BLUEPRINTS_DIR=
